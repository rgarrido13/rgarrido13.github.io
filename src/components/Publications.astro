---
const publications = [
  {
    title: "A Prospective Real-time Early Warning System to Anticipate Onsets and Peaks of Respiratory Diseases Outbreaks at the State Level in the US: A Transfer Learning Approach",
    venue: "medRxiv (preprint)",
    link: "https://www.medrxiv.org/content/medrxiv/early/2025/10/13/2025.10.10.25337739.full.pdf",
  },
  {
    title: "Resolving parameter uncertainty in outbreak models through population-level serological surveillance",
    venue: "medRxiv (preprint)",
    link: "https://www.medrxiv.org/content/10.1101/2025.10.09.25337678v2.full.pdf",
  },
  {
    title: "Uncovering the post-pandemic timing of influenza, RSV, and COVID-19 driving seasonal influenza-like illness in the United States: a retrospective ecological study",
    venue: "The Lancet Regional Health \u2013 Americas",
    link: "https://www.thelancet.com/journals/lanam/article/PIIS2667-193X(25)00370-9/fulltext",
  },
];
---

<section id="publications">
  <div class="container">
    <h2 class="section-title">Publications</h2>
    <div class="pub-list">
      {publications.map((pub, i) => (
        <a href={pub.link} target="_blank" class="pub-item card">
          <span class="pub-number">{String(i + 1).padStart(2, '0')}</span>
          <div class="pub-content">
            <h3>{pub.title}</h3>
            <span class="pub-venue">{pub.venue}</span>
          </div>
          <span class="pub-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pub-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .pub-item:hover {
    color: inherit;
  }

  .pub-number {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }

  .pub-content {
    flex: 1;
  }

  .pub-content h3 {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 0.35rem;
  }

  .pub-venue {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .pub-arrow {
    color: var(--color-accent);
    font-size: 1.1rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .pub-item:hover .pub-arrow {
    opacity: 1;
  }
</style>
